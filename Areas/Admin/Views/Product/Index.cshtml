@model IEnumerable<TINH_FINAL_2256.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm - Admin";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Admin</a></li>
        <li class="breadcrumb-item active"><i class="bi bi-box me-1"></i>Quản lý sản phẩm</li>
    </ol>
</nav>

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="page-title mb-0">
            <i class="bi bi-box me-2"></i>Quản lý sản phẩm
        </h1>
        <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm
        </a>
    </div>
    <p class="text-secondary">Quản lý toàn bộ sản phẩm trong hệ thống</p>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr class="bg-light">
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá bán</th>
                    <th>Danh mục</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">
                            <i class="bi bi-inbox" style="font-size: 2rem; color: var(--text-secondary);"></i>
                            <p class="text-secondary mt-2">Chưa có sản phẩm nào</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" width="60" height="60" alt="@item.Name" class="rounded" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                        <i class="bi bi-image text-secondary"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <small class="text-secondary">ID: @item.Id</small>
                            </td>
                            <td>
                                <span class="badge bg-danger">@item.Price.ToString("#,##0") đ</span>
                            </td>
                            <td>
                                <span class="badge bg-info">@item.Category?.Name</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Display" asp-route-id="@item.Id" 
                                       class="btn btn-outline-primary" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@item.Id" 
                                       class="btn btn-outline-warning" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" 
                                       class="btn btn-outline-danger" title="Xóa"
                                       onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
