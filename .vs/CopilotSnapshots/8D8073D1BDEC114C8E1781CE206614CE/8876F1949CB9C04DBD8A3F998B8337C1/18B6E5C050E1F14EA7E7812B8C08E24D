@model IEnumerable<TINH_FINAL_2256.Models.Product>

@{
    ViewData["Title"] = "Danh mục";
    int numOfQuantity = 1;
    string bannerImage = Url.Content("~/images/banner-placeholder.jpg");
    var selectedCategory = ViewData["SelectedCategory"] as string ?? string.Empty;
    var categories = ViewBag.Categories as IEnumerable<TINH_FINAL_2256.Models.Category> ?? Enumerable.Empty<TINH_FINAL_2256.Models.Category>();

    // define top groups: pairings as requested
    var topGroups = new List<List<string>> {
        new List<string> { "Điện thoại", "Máy tính bảng" },
        new List<string> { "Phụ kiện", "Tai nghe" },
        new List<string> { "Khuyến mãi" }
    };

    if (Model != null)
    {
        foreach (var _p in Model)
        {
            if (!string.IsNullOrEmpty(_p.ImageUrl))
            {
                bannerImage = _p.ImageUrl;
                break;
            }
        }
    }
}

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="page-title mb-0">Danh mục</h1>
        </div>
        <a class="btn btn-outline-secondary">Dùng bộ lọc ngay</a>
    </div>
</div>

<div class="container mb-4 position-relative">
    <div class="row">
        <div class="col-lg-3 d-none d-lg-block">
            <div class="left-panel">
                <ul class="nav flex-column">
                    @foreach (var cat in categories)
                    {
                        var isActive = string.Equals(selectedCategory, cat.Name, StringComparison.OrdinalIgnoreCase);
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home", new { category = cat.Name })" class="nav-link category-link @(isActive ? "active" : "")" data-category="@cat.Name">@cat.Name</a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="card overflow-hidden shadow-sm">
                <img src="@bannerImage" class="img-fluid w-100 home-banner" alt="Banner" />
            </div>

            <!-- Top grouped tabs -->
            <div class="mt-3">
                @foreach (var group in topGroups)
                {
                    <div class="d-flex gap-3 mb-2">
                        @foreach (var label in group)
                        {
                            <a class="btn btn-outline-secondary px-4 py-2">@label</a>
                        }
                    </div>
                }
            </div>

            <!-- Category chips (rounded rectangles) -->
            <div class="d-flex flex-wrap gap-2 mb-3 mt-3">
                @foreach (var cat in categories)
                {
                    <a class="category-chip btn" href="@Url.Action("Index", "Home", new { category = cat.Name })" data-category="@cat.Name">@cat.Name</a>
                }
            </div>

            <!-- Products grid -->
            <section class="py-4">
                <div class="container px-4 px-lg-5">
                    <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-start" id="productGrid">

                        @if (Model == null || !Model.Any())
                        {
                            <div class="col-12">
                                <div class="alert alert-info">Chưa có sản phẩm nào trong danh mục này.</div>
                            </div>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                var categoryName = item.Category?.Name ?? "";
                                <div class="col mb-5 product-item" data-category="@categoryName">
                                    <div class="card h-100">

                                        <img src="@item.ImageUrl" class="card-img-top product-image" alt="@item.Name" />

                                        <div class="card-body d-flex flex-column">

                                            <h6 class="card-title mb-2 text-truncate">@item.Name</h6>

                                            <div class="mt-auto">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <div class="text-muted small">@item.Category?.Name</div>
                                                    <div class="fw-bold">@item.Price.ToString("#,##0") Vnđ</div>
                                                </div>

                                                <div class="actions">
                                                    <a asp-controller="ShoppingCart"
                                                       asp-action="AddToCart"
                                                       asp-route-productId="@item.Id"
                                                       asp-route-quantity="@numOfQuantity"
                                                       class="btn btn-outline-dark btn-sm">
                                                        <i class="bi-cart-fill me-1"></i>
                                                        Thêm vào giỏ
                                                    </a>

                                                    @* Edit/Delete only for admins *@
                                                    @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                                                    {
                                                        <a asp-controller="Product" asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                                                        <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">Xóa</a>
                                                    }

                                                    <a asp-controller="Product" asp-action="Display" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Xem</a>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<footer class="text-center py-4 text-muted">
    © @DateTime.Now.Year 3TLH Phone - Giao diện đơn giản
</footer>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function setActiveCategory(cat) {
                // highlight chips and left panel
                document.querySelectorAll('.category-chip, .left-panel .nav-link').forEach(function (el) {
                    el.classList.toggle('active', el.getAttribute('data-category') === cat);
                });

                // scroll to product area
                var grid = document.getElementById('productGrid');
                if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            // initial state
            var initial = '@selectedCategory';
            if (initial && initial !== '') setActiveCategory(initial);
        });
    </script>
}