@model TINH_FINAL_2256.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2>Chi tiết đơn hàng #@Model.Id</h2>
<p>Người mua : @Model.ApplicationUser?.Email</p>
<p>Ngày: @Model.OrderDate.ToString("g")</p>
<p>Tổng: @Model.TotalPrice.ToString("#,##0") Vn</p>

<table class="table">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model.OrderDetails)
        {
            <tr>
                <td>@d.Product?.Name</td>
                <td>@d.Quantity</td>
                <td>@($"{d.Price:#,##0} Vnđ")</td>
                <td>@($"{(d.Quantity * d.Price):#,##0} Vnđ")</td>
            </tr>
        }
    </tbody>
</table>