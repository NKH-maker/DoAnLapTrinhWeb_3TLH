@model TINH_FINAL_2256.Models.Order
@using TINH_FINAL_2256.Extensions
@using System.Linq

@{
    ViewData["Title"] = "Thanh toán";
    var cart = Context.Session.GetObjectFromJson<TINH_FINAL_2256.Models.ShoppingCart>("Cart") ?? new TINH_FINAL_2256.Models.ShoppingCart();
    var subtotal = cart.Items?.Any() == true ? cart.Items.Sum(i => i.Price * i.Quantity) : 0m;
}

<div class="container my-4">
    <h2 class="mb-3">Thanh toán</h2>
    @if (cart == null || cart.Items == null || !cart.Items.Any())
    {
        <div class="alert alert-info">Giỏ hàng trống. <a asp-controller="Product" asp-action="Index">Tiếp tục mua sắm</a></div>
    }
    else
    {
        <div class="row">
            <div class="col-md-7">
                <div class="card p-3">
                    <h5>Thông tin giao hàng</h5>
                    <hr />
                    <form asp-controller="ShoppingCart" asp-action="Checkout" method="post">
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label">Địa chỉ nhận hàng</label>
                            <input asp-for="ShippingAddress" class="form-control" />
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">Ghi chú</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary">Đặt hàng</button>
                    </form>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card p-3">
                    <h6>Tóm tắt đơn hàng</h6>
                    <hr />
                    <ul class="list-unstyled mb-3">
                        @foreach (var item in cart.Items)
                        {
                            <li class="d-flex justify-content-between mb-2">
                                <div>
                                    <div class="fw-bold">@item.Name</div>
                                    <div class="text-muted-small">Số lượng: @item.Quantity</div>
                                </div>
                                <div class="text-end">@{(item.Price* item.Quantity):"#,##0")} Vnđ</div>/
                            </li>
                        }
                    </ul>

                    <p class="d-flex justify-content-between fw-bold"><span>Tổng:</span><span>@subtotal.ToString("#,##0") Vnđ</span></p>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}