@model IEnumerable<TINH_FINAL_2256.Models.Product>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
    int numOfQuantity = 1;
    string bannerImage = Url.Content("~/images/banner-placeholder.jpg");
    var selectedCategory = ViewData["SelectedCategory"] as string ?? string.Empty;
    var categories = ViewBag.Categories as IEnumerable<TINH_FINAL_2256.Models.Category> ?? Enumerable.Empty<TINH_FINAL_2256.Models.Category>();

    if (Model != null)
    {
        foreach (var _p in Model)
        {
            if (!string.IsNullOrEmpty(_p.ImageUrl))
            {
                bannerImage = _p.ImageUrl;
                break;
            }
        }
    }
}

<!-- Hero Banner Section - Full Width -->
<div class="mb-5">
    <div class="card overflow-hidden shadow-lg border-0">
        <img src="@bannerImage" class="home-banner" alt="Banner" />
    </div>
</div>

<!-- Main Content Section -->
<div class="container px-0">
    <div class="row g-4">
        <!-- Left Sidebar - Categories -->
        <div class="col-lg-2">
            <div class="left-panel sticky-top" style="top: 100px;">
                <h6 class="fw-bold mb-3 text-dark" style="font-size: 1rem; letter-spacing: 0.5px;">
                    <i class="bi bi-list me-2"></i>DANH MỤC
                </h6>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")" 
                           class="nav-link @(string.IsNullOrEmpty(selectedCategory) ? "active" : "")"
                           style="font-size: 0.95rem; padding: 0.6rem 0.8rem;">
                            <i class="bi bi-star me-2"></i><span style="font-weight: 500;">Tất cả</span>
                        </a>
                    </li>
                    @foreach (var cat in categories)
                    {
                        var isActive = string.Equals(selectedCategory, cat.Name, StringComparison.OrdinalIgnoreCase);
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home", new { category = cat.Name })" 
                               class="nav-link @(isActive ? "active" : "")" 
                               data-category="@cat.Name"
                               style="font-size: 0.95rem; padding: 0.6rem 0.8rem;">
                                <i class="bi bi-tag me-2"></i><span style="font-weight: 500;">@cat.Name</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Right Content Area - Products -->
        <div class="col-lg-10">
            <!-- Page Header -->
            <div class="mb-4">
                <h2 class="fw-bold text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px; margin-bottom: 0.5rem;">
                    <i class="bi bi-bag me-2"></i>Danh mục sản phẩm
                </h2>
                <p class="text-secondary" style="font-size: 1rem;">Khám phá bộ sưu tập điện thoại, laptop và phụ kiện chính hãng</p>
            </div>

            <!-- Category Filter Chips -->
            <div class="mb-4">
                <div class="d-flex align-items-center mb-3">
                    <h6 class="mb-0 fw-bold text-dark" style="font-size: 0.95rem;">
                        <i class="bi bi-funnel me-2"></i>LỌC THEO DANH MỤC:
                    </h6>
                </div>
                <div class="d-flex flex-wrap gap-2" style="overflow-y: visible;">
                    <a href="@Url.Action("Index", "Home")" 
                       class="category-chip @(string.IsNullOrEmpty(selectedCategory) ? "active" : "")"
                       style="font-size: 0.9rem; font-weight: 600;">
                        Tất cả
                    </a>
                    @foreach (var cat in categories)
                    {
                        <a class="category-chip @(string.Equals(selectedCategory, cat.Name, StringComparison.OrdinalIgnoreCase) ? "active" : "")" 
                           href="@Url.Action("Index", "Home", new { category = cat.Name })" 
                           data-category="@cat.Name"
                           style="font-size: 0.9rem; font-weight: 600;">
                            @cat.Name
                        </a>
                    }
                </div>
            </div>

            <!-- Products Grid -->
            <section>
                @if (Model == null || !Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: var(--text-secondary);"></i>
                        <h5 class="mt-3 text-secondary fw-bold">Chưa có sản phẩm nào</h5>
                        <p class="text-secondary">Danh mục này hiện không có sản phẩm. Vui lòng chọn danh mục khác.</p>
                    </div>
                }
                else
                {
                    <div class="row g-3" id="productGrid">
                        @foreach (var item in Model)
                        {
                            var categoryName = item.Category?.Name ?? "";
                            <div class="col-6 col-sm-6 col-md-4 col-lg-3 product-item" data-category="@categoryName">
                                <div class="card h-100 product-card shadow-sm" style="border: none; border-radius: 10px;">
                                    <!-- Product Image -->
                                    <div class="position-relative overflow-hidden" style="background: var(--light-bg); height: 220px;">
                                        <img src="@item.ImageUrl" class="card-img-top product-image" alt="@item.Name" 
                                             style="width: 100%; height: 100%; object-fit: cover;" />
                                        @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                                        {
                                            <div class="position-absolute top-0 end-0 m-2">
                                                <span class="badge bg-warning text-dark" style="font-size: 0.75rem;">
                                                    <i class="bi bi-shield-check"></i> Admin
                                                </span>
                                            </div>
                                        }
                                    </div>

                                    <!-- Product Info -->
                                    <div class="card-body d-flex flex-column p-3">
                                        <h6 class="card-title fw-bold text-dark" style="font-size: 0.95rem; line-height: 1.3; min-height: 2.6rem;">
                                            @item.Name
                                        </h6>
                                        
                                        <div class="mb-2">
                                            <small class="text-secondary d-block" style="font-size: 0.8rem;">
                                                <i class="bi bi-tag me-1"></i>@item.Category?.Name
                                            </small>
                                        </div>

                                        <div class="product-price mb-3 fw-bold text-danger" style="font-size: 1.1rem;">
                                            @item.Price.ToString("#,##0") đ
                                        </div>

                                        <!-- Actions -->
                                        <div class="product-actions mt-auto d-flex gap-1" style="flex-wrap: wrap;">
                                            <a asp-controller="ShoppingCart"
                                               asp-action="AddToCart"
                                               asp-route-productId="@item.Id"
                                               asp-route-quantity="@numOfQuantity"
                                               class="btn btn-sm btn-primary flex-grow-1"
                                               title="Thêm vào giỏ hàng"
                                               style="font-size: 0.85rem; padding: 0.4rem 0.6rem;">
                                                <i class="bi bi-cart-plus"></i>
                                            </a>

                                            <a asp-controller="Product" asp-action="Display" asp-route-id="@item.Id" 
                                               class="btn btn-sm btn-outline-secondary flex-grow-1"
                                               title="Xem chi tiết"
                                               style="font-size: 0.85rem; padding: 0.4rem 0.6rem;">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                                            {
                                                <a asp-controller="Product" asp-action="Update" asp-route-id="@item.Id" 
                                                   class="btn btn-sm btn-warning flex-grow-1"
                                                   title="Chỉnh sửa"
                                                   style="font-size: 0.85rem; padding: 0.4rem 0.6rem;">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" 
                                                   class="btn btn-sm btn-danger flex-grow-1"
                                                   title="Xóa"
                                                   onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');"
                                                   style="font-size: 0.85rem; padding: 0.4rem 0.6rem;">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.category-chip').forEach(chip => {
                chip.addEventListener('click', function (e) {
                    document.querySelectorAll('.category-chip').forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                });
            });
        });
    </script>
}