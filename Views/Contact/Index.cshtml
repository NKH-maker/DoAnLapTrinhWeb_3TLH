@model TINH_FINAL_2256.Models.ContactFormModel

@{
    ViewData["Title"] = "Liên hệ với chúng tôi";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a></li>
        <li class="breadcrumb-item active"><i class="bi bi-headset me-1"></i>Liên hệ</li>
    </ol>
</nav>

<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <!-- Contact Form -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="page-title mb-1">
                    <i class="bi bi-chat-dots me-2"></i>Gửi tin nhắn cho chúng tôi
                </h2>
                <p class="text-secondary mb-4">Hãy để lại thông tin của bạn và chúng tôi sẽ liên hệ lại sớm nhất.</p>

                <!-- Success Message from TempData -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Error Message from TempData -->
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Send" method="post" class="needs-validation" novalidate>
                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">
                            <i class="bi bi-person me-2 text-primary"></i>Họ và tên
                        </label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập họ và tên của bạn" required />
                        <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">
                            <i class="bi bi-envelope me-2 text-primary"></i>Địa chỉ Email
                        </label>
                        <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="example@email.com" required />
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Subject -->
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-semibold">
                            <i class="bi bi-bookmark me-2 text-primary"></i>Chủ Đề
                        </label>
                        <input asp-for="Subject" class="form-control form-control-lg" placeholder="Chủ Đề liên hệ" />
                    </div>

                    <!-- Message -->
                    <div class="mb-4">
                        <label asp-for="Message" class="form-label fw-semibold">
                            <i class="bi bi-chat me-2 text-primary"></i>Nội dung tin nhắn
                        </label>
                        <textarea asp-for="Message" class="form-control" style="resize: vertical; min-height: 150px;" 
                                  placeholder="Nhập nội dung tin nhắn của bạn..." required></textarea>
                        <span asp-validation-for="Message" class="text-danger small d-block mt-1"></span>
                        <small class="text-secondary d-block mt-1">Tối thiểu 10 ký tự</small>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid">
                        <button class="btn btn-primary btn-lg fw-semibold" type="submit">
                            <i class="bi bi-send me-2"></i>Gửi tin nhắn
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Contact Info Sidebar -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-3">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Thông tin liên hệ
                </h5>
                
                <!-- Address -->
                <div class="mb-3">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-geo-alt text-success me-3 mt-1" style="font-size: 1.3rem;"></i>
                        <div>
                            <p class="mb-1 fw-bold">Địa chỉ</p>
                            <p class="text-secondary small mb-0">
                                123 Xa Lộ Hà Nội, Thủ Đức, TP. Hồ Chí Minh
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Phone -->
                <div class="mb-3">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-telephone text-success me-3 mt-1" style="font-size: 1.3rem;"></i>
                        <div>
                            <p class="mb-1 fw-bold">Điện thoại</p>
                            <p class="text-secondary small mb-0">
                                <a href="tel:+84123456789" class="text-decoration-none text-secondary fw-semibold">
                                    (+84) 123 456 789
                                </a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-envelope text-info me-3 mt-1" style="font-size: 1.3rem;"></i>
                        <div>
                            <p class="mb-1 fw-bold">Email</p>
                            <p class="text-secondary small mb-0">
                                <a href="mailto:contact@3tlhphone.com" class="text-decoration-none text-secondary fw-semibold">
                                    contact@3tlhphone.com
                                </a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Hours -->
                <div class="mb-3">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-clock text-warning me-3 mt-1" style="font-size: 1.3rem;"></i>
                        <div>
                            <p class="mb-1 fw-bold">Giờ làm việc</p>
                            <p class="text-secondary small mb-0">
                                Thứ 2 - Thứ 7: 9:00 - 21:00<br />
                                Chủ nhật: 10:00 - 20:00
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Follow Us -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-3">
                    <i class="bi bi-share me-2 text-primary"></i>Theo dõi chúng tôi
                </h5>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-primary btn-sm rounded-circle" title="Facebook">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" class="btn btn-outline-info btn-sm rounded-circle" title="Twitter">
                        <i class="bi bi-twitter"></i>
                    </a>
                    <a href="#" class="btn btn-outline-danger btn-sm rounded-circle" title="Instagram">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" class="btn btn-outline-secondary btn-sm rounded-circle" title="YouTube">
                        <i class="bi bi-youtube"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function (e) {
                    if (!form.checkValidity()) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                    form.classList.add('was-validated');
                });
            }

            // Auto-hide success/error messages after 5 seconds
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
}