@using Microsoft.AspNetCore.Identity
@using TINH_FINAL_2256.Extensions
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav" style="gap: 0.5rem;">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center text-white" 
               style="padding: 0.4rem 0.8rem; font-size: 0.9rem;" 
               href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-1"></i>
                <span class="d-none d-md-inline">@User.Identity?.Name</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li><a class="dropdown-item" asp-controller="Account" asp-action="Manage">
                    <i class="bi bi-person me-2"></i>Hồ sơ
                </a></li>
                <li><a class="dropdown-item" asp-controller="Support" asp-action="Chat">
                    <i class="bi bi-chat-dots me-2"></i>Hỗ trợ
                </a></li>

                @* Admin quick links *@
                @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                {
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
                    </a></li>
                    <li><a class="dropdown-item" asp-controller="ShoppingCart" asp-action="ExportOrdersToExcel">
                        <i class="bi bi-download me-2"></i>Xuất Excel (Đơn hàng)
                    </a></li>
                    <li><a class="dropdown-item" href="/hangfire" target="_blank">
                        <i class="bi bi-clock-history me-2"></i>Hangfire Dashboard
                    </a></li>
                }

                <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#cartModal">
                    <i class="bi bi-cart3 me-2"></i>Giỏ hàng
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form class="dropdown-item" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Product", new { area = "" })" method="post" style="padding: 0; cursor: pointer;">
                        <button type="submit" class="w-100 text-start" style="border: none; background: none; padding: 0.5rem 1rem; font-size: 0.95rem;">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white" style="padding: 0.4rem 0.8rem; font-size: 0.9rem;" 
               asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus me-1"></i><span class="d-none d-md-inline">Đăng ký</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" style="padding: 0.4rem 0.8rem; font-size: 0.9rem;" 
               asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i><span class="d-none d-md-inline">Đăng nhập</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" href="#" data-bs-toggle="modal" data-bs-target="#cartModal" style="padding: 0.4rem 0.8rem;">
                <i class="bi bi-cart3 me-1"></i><span class="d-none d-md-inline">Giỏ hàng</span>
            </a>
        </li>
    }
</ul>
