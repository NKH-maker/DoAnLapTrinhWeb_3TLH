@using TINH_FINAL_2256.Extensions
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 3TLH Phone</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap icons-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TINH_FINAL_2256.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <!-- Modern Professional Header -->
        <div class="top-header" style="padding: 0.6rem 0;">
            <div class="container" style="padding: 0 15px;">
                <div class="row align-items-center g-2" style="margin: 0;">
                    <!-- Logo -->
                    <div class="col-auto">
                        <a class="text-white text-decoration-none fw-bold" style="font-size: 1.3rem;" 
                            asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-phone me-2"></i>3TLH Phone
                        </a>
                    </div>

                    <!-- Navigation links -->
                    <div class="col d-none d-md-block">
                        <ul class="nav gap-1" style="margin: 0;">
                            <li class="nav-item">
                                <a class="nav-link text-white" style="padding: 0.4rem 0.8rem; font-size: 0.9rem;" 
                                   asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house me-1"></i>Trang chủ
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" style="padding: 0.4rem 0.8rem; font-size: 0.9rem;" 
                                   asp-area="" asp-controller="Product" asp-action="Index">
                                    <i class="bi bi-box me-1"></i>Sản phẩm
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Search form -->
                    <div class="col-12 col-md-auto flex-md-grow-1" style="padding: 0;">
                        <form asp-controller="Product" asp-action="Index" method="get" class="w-100">
                            <div class="input-group input-group-sm">
                                <input type="search" name="q" class="form-control top-search-input"
                                    placeholder="Tìm điện thoại..." 
                                    value="@Context.Request.Query["q"]" 
                                    aria-label="Search"
                                    style="padding: 0.5rem 0.8rem; font-size: 0.9rem;" />
                                <button class="btn btn-light" type="submit" style="padding: 0.5rem 0.8rem;">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- User Actions -->
                    <div class="col-auto d-flex align-items-center gap-2">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Cart Modal placed at root level to avoid nested dropdown/modal issues -->
    <div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-end modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="cartModalLabel">
                        <i class="bi bi-cart3 me-2"></i>Giỏ hàng & Đơn hàng
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (User.IsInRole("Admin"))
                    {
                        <div id="adminOrdersContainer">
                            <p class="text-center">Đang tải đơn hàng khách hàng...</p>
                        </div>
                    }
                    else
                    {
                        <div id="cartSummaryContainer">
                            @Html.Partial("_CartSummaryPartial", Context.Session.GetObjectFromJson<TINH_FINAL_2256.Models.ShoppingCart>("Cart") ?? new TINH_FINAL_2256.Models.ShoppingCart())
                        </div>
                        <hr />
                        <div id="recentOrdersContainer"></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- All Orders Modal for Customer -->
    <div class="modal fade" id="allOrdersModal" tabindex="-1" aria-labelledby="allOrdersModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="allOrdersModalLabel">
                        <i class="bi bi-receipt me-2"></i>Tất cả đơn hàng của tôi
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="allOrdersContainer">
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Order Modal -->
    <div class="modal fade" id="editOrderModal" tabindex="-1" aria-labelledby="editOrderModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editOrderModalLabel">
                        <i class="bi bi-pencil me-2"></i>Chỉnh sửa đơn hàng
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editOrderForm" method="post" asp-controller="ShoppingCart" asp-action="UpdateOrder">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <input type="hidden" id="editOrderId" name="id" />

                        <div class="mb-3">
                            <label for="editShippingAddress" class="form-label">
                                <i class="bi bi-geo-alt me-2"></i>Địa chỉ giao hàng
                            </label>
                            <textarea class="form-control" id="editShippingAddress" name="shippingAddress" rows="3" required></textarea>
                            <small class="text-muted">Nhập địa chỉ giao hàng mới</small>
                        </div>

                        <div class="mb-3">
                            <label for="editPhoneNumber" class="form-label">
                                <i class="bi bi-telephone me-2"></i>Số điện thoại
                            </label>
                            <input type="tel" class="form-control" id="editPhoneNumber" name="phoneNumber" pattern="[0-9\-\+\(\)\s]+" required />
                            <small class="text-muted">Nhập số điện thoại mới</small>
                        </div>

                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            <small>Bạn chỉ có thể chỉnh sửa đơn hàng khi chưa được giao hoặc hủy.</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x me-1"></i>Hủy
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check me-1"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="container" style="margin-top: 2rem; margin-bottom: 2rem;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Contact Floating Button -->
    <a class="contact-btn" asp-controller="Contact" asp-action="Index" role="button" aria-label="Liên hệ"> 
        <i class="bi bi-headset"></i> 
        <span class="d-none d-sm-inline">Liên hệ</span>
    </a>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h6 class="fw-bold mb-2" style="font-size: 1rem;">3TLH Phone</h6>
                    <p class="small text-secondary mb-0">Cửa hàng bán điện thoại, laptop và phụ kiện chính hãng</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="small text-secondary mb-0">
                        &copy; @DateTime.Now.Year 3TLH Phone. Tất cả các quyền được bảo lưu.
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Function to load all customer orders
        function loadAllCustomerOrders() {
            fetch('@Url.Action("GetAllCustomerOrdersPartial", "ShoppingCart")', { credentials: 'same-origin' })
                .then(function (res) { if (!res.ok) throw new Error('Status: ' + res.status + ' ' + res.statusText); return res.text(); })
                .then(function (html) {
                    var container = document.getElementById('allOrdersContainer');
                    if (container) container.innerHTML = html;
                })
                .catch(function (err) {
                    console.error('Error loading all orders', err);
                    var container = document.getElementById('allOrdersContainer');
                    if (container) container.innerHTML = '<p class="text-danger">Lỗi tải đơn hàng: ' + (err.message || '') + '</p>';
                });
        }

        // Function to open edit order modal
        function openEditOrderModal(orderId, shippingAddress, phoneNumber) {
            document.getElementById('editOrderId').value = orderId;
            document.getElementById('editShippingAddress').value = shippingAddress;
            document.getElementById('editPhoneNumber').value = phoneNumber;

            var editModal = new bootstrap.Modal(document.getElementById('editOrderModal'));
            editModal.show();
        }

        // Function to cancel order
        function cancelOrder(orderId) {
            if (confirm('Bạn có chắc chắn muốn hủy đơn hàng #' + orderId + '?')) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("CancelOrder", "ShoppingCart")';

                var idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = orderId;
                form.appendChild(idInput);

                var tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                if (tokenElement) {
                    var tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = tokenElement.value;
                    form.appendChild(tokenInput);
                }

                document.body.appendChild(form);
                form.submit();
            }
        }

        // Function to view order details (close modal then navigate)
        function viewOrderDetails(orderId) {
            try {
                // Hide any open modals first
                document.querySelectorAll('.modal.show').forEach(function (modalEl) {
                    var modalInstance = bootstrap.Modal.getInstance(modalEl) || bootstrap.Modal.getOrCreateInstance(modalEl);
                    if (modalInstance) modalInstance.hide();
                });
            } catch (e) {
                console.warn('Error hiding modal before navigating', e);
            }

            var baseUrl = '@Url.Action("OrderDetails", "ShoppingCart")';
            // navigate with query param to ensure routing works
            window.location.href = baseUrl + '?id=' + encodeURIComponent(orderId);
        }

        document.addEventListener('DOMContentLoaded', function () {
            var cartModal = document.getElementById('cartModal');
            if (!cartModal) return;

            var isAuthenticated = @((User.Identity?.IsAuthenticated ?? false).ToString().ToLower());
            var isAdmin = @(User.IsInRole("Admin").ToString().ToLower());

            cartModal.addEventListener('shown.bs.modal', function () {
                // For admin - load all customer orders
                if (isAdmin) {
                    fetch('@Url.Action("GetAdminOrdersPartial", "ShoppingCart")', { credentials: 'same-origin' })
                        .then(function (res) { if (!res.ok) throw new Error('Status: ' + res.status + ' ' + res.statusText); return res.text(); })
                        .then(function (html) {
                            var container = document.getElementById('adminOrdersContainer');
                            if (container) container.innerHTML = html;
                        })
                        .catch(function (err) {
                            console.error('Error loading admin orders', err);
                            var container = document.getElementById('adminOrdersContainer');
                            if (container) container.innerHTML = '<p class="text-danger">Lỗi tải đơn hàng: ' + (err.message || '') + '</p>';
                        });
                } else {
                    // For customer - load cart summary and recent orders
                    fetch('@Url.Action("CartSummary", "ShoppingCart")', { credentials: 'same-origin' })
                        .then(function (res) { if (!res.ok) throw new Error('Status: ' + res.status + ' ' + res.statusText); return res.text(); })
                        .then(function (html) {
                            var container = document.getElementById('cartSummaryContainer');
                            if (container) container.innerHTML = html;
                        })
                        .catch(function (err) { console.error('Error loading cart summary', err); });

                    // load recent orders only for authenticated customers
                    if (isAuthenticated) {
                        fetch('@Url.Action("GetRecentOrders", "ShoppingCart")', { credentials: 'same-origin' })
                            .then(function (res) { if (!res.ok) throw new Error('Status: ' + res.status + ' ' + res.statusText); return res.text(); })
                            .then(function (html) {
                                var recent = document.getElementById('recentOrdersContainer');
                                if (recent) recent.innerHTML = html;
                            })
                            .catch(function (err) {
                                console.error('Error loading recent orders', err);
                                var recent = document.getElementById('recentOrdersContainer');
                                if (recent) recent.innerHTML = '<p class="text-danger">Lỗi tải đơn hàng: ' + (err.message || '') + '</p>';
                            });
                    }
                }
            });

            // Clean up when modal hidden (remove leftover backdrops if any)
            cartModal.addEventListener('hidden.bs.modal', function () {
                // remove any stray modal-backdrop
                document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
            });
        });

        // Script for All Orders Modal
        document.addEventListener('DOMContentLoaded', function () {
            var allOrdersModal = document.getElementById('allOrdersModal');
            if (!allOrdersModal) return;

            allOrdersModal.addEventListener('shown.bs.modal', function () {
                var container = document.getElementById('allOrdersContainer');
                if (container) {
                    // Clear previous content
                    container.innerHTML = '';

                    // Show loading spinner
                    container.innerHTML = `
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>`;

                    // Fetch all orders for the customer
                    fetch('@Url.Action("GetAllCustomerOrdersPartial", "ShoppingCart")', { credentials: 'same-origin' })
                        .then(function (res) { if (!res.ok) throw new Error('Status: ' + res.status + ' ' + res.statusText); return res.text(); })
                        .then(function (html) {
                            // Populate the modal with the fetched content
                            container.innerHTML = html;
                        })
                        .catch(function (err) {
                            console.error('Error loading all orders', err);
                            container.innerHTML = '<p class="text-danger">Lỗi tải tất cả đơn hàng: ' + (err.message || '') + '</p>';
                        });
                }
            });

            // Clean up when modal hidden (remove leftover backdrops if any)
            allOrdersModal.addEventListener('hidden.bs.modal', function () {
                // remove any stray modal-backdrop
                document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
            });
        });

        // Script for Edit Order Modal
        document.addEventListener('DOMContentLoaded', function () {
            var editOrderModal = document.getElementById('editOrderModal');
            if (!editOrderModal) return;

            editOrderModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget; // Button that triggered the modal
                var orderId = button.getAttribute('data-order-id'); // Extract info from data-* attributes
                
                // If order ID is not found, do nothing
                if (!orderId) return;

                var shippingAddress = button.getAttribute('data-shipping-address') || '';
                var phoneNumber = button.getAttribute('data-phone-number') || '';

                // Update the modal's content.
                var modalTitle = editOrderModal.querySelector('.modal-title');
                var orderIdInput = editOrderModal.querySelector('#editOrderId');
                var shippingAddressTextarea = editOrderModal.querySelector('#editShippingAddress');
                var phoneNumberInput = editOrderModal.querySelector('#editPhoneNumber');

                if (modalTitle) {
                    modalTitle.textContent = 'Chỉnh sửa đơn hàng #' + orderId;
                }

                if (orderIdInput) {
                    orderIdInput.value = orderId;
                }

                if (shippingAddressTextarea) {
                    shippingAddressTextarea.value = shippingAddress;
                }

                if (phoneNumberInput) {
                    phoneNumberInput.value = phoneNumber;
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
