@model IEnumerable<TINH_FINAL_2256.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
    int numOfQuantity = 1;
    var query = ViewData["SearchQuery"] as string ?? Context.Request.Query["q"].ToString();
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a></li>
        <li class="breadcrumb-item active"><i class="bi bi-box me-1"></i>Sản phẩm</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="page-title mb-1">
                <i class="bi bi-box me-2"></i>Tất cả sản phẩm
            </h1>
            @if (!string.IsNullOrWhiteSpace(query))
            {
                <p class="page-subtitle">
                    Kết quả tìm kiếm cho: <strong>"@query"</strong>
                </p>
            }
            else
            {
                <p class="page-subtitle">Khám phá bộ sưu tập đầy đủ của chúng tôi</p>
            }
        </div>

        @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
        {
            <a asp-action="Add" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm
            </a>
        }
    </div>
</div>

<!-- Products Grid -->
@if (Model == null || !Model.Any())
{
    <div class="card shadow-sm p-5 text-center">
        <i class="bi bi-inbox" style="font-size: 4rem; color: var(--text-secondary);"></i>
        <h4 class="mt-3 text-secondary">Không tìm thấy sản phẩm</h4>
        <p class="text-secondary mb-4">
            @if (!string.IsNullOrWhiteSpace(query))
            {
                <span>Không có kết quả tìm kiếm cho "<strong>@query</strong>". Vui lòng thử với từ khóa khác.</span>
            }
            else
            {
                <span>Hiện không có sản phẩm nào trong danh mục này.</span>
            }
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-arrow-left me-2"></i>Quay lại trang chủ
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-6 col-sm-6 col-md-4 col-lg-3 product-item">
                <div class="card h-100 product-card shadow-sm">
                    <!-- Product Image -->
                    <div class="position-relative overflow-hidden" style="background: var(--light-bg);">
                        <img src="@item.ImageUrl" class="card-img-top product-image" alt="@item.Name" />
                        @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                        {
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-shield-check"></i> Admin
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Product Info -->
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">@item.Name</h6>

                        <div class="mb-2">
                            <small class="text-secondary d-block">
                                <i class="bi bi-tag me-1"></i>@item.Category?.Name
                            </small>
                        </div>

                        <div class="product-price mb-3">
                            @item.Price.ToString("#,##0") đ
                        </div>

                        <!-- Actions -->
                        <div class="product-actions mt-auto">
                            <a asp-controller="ShoppingCart"
                               asp-action="AddToCart"
                               asp-route-productId="@item.Id"
                               asp-route-quantity="@numOfQuantity"
                               class="btn btn-sm btn-primary flex-grow-1"
                               title="Thêm vào giỏ hàng">
                                <i class="bi bi-cart-plus"></i>
                            </a>

                            <a asp-action="Display" asp-route-id="@item.Id" 
                               class="btn btn-sm btn-outline-secondary flex-grow-1"
                               title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>

                            @if (User.IsInRole(TINH_FINAL_2256.Models.SD.Role_Admin))
                            {
                                <a asp-action="Update" asp-route-id="@item.Id" 
                                   class="btn btn-sm btn-warning flex-grow-1"
                                   title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" 
                                   class="btn btn-sm btn-danger flex-grow-1"
                                   title="Xóa"
                                   onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Back to Home Button -->
    <div class="text-center mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-house me-2"></i>Quay lại trang chủ
        </a>
    </div>
}