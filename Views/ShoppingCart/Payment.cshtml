@model TINH_FINAL_2256.Models.Order
@using System.Linq

@{
    ViewData["Title"] = "Thanh toán";
    var order = Model;
    var total = order.TotalPrice;
}

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <h2 class="mb-0">Thanh toán</h2>
        <span class="badge bg-success fs-6">Mã đơn: #@order.Id</span>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="mb-2">Quét mã QR để thanh toán</h5>
                    <div class="text-muted mb-3">
                        Vui lòng chuyển khoản đúng số tiền bên dưới, sau đó bấm nút xác nhận.
                    </div>

                    <div class="d-flex flex-column flex-md-row align-items-center gap-4">
                        <div class="bg-white p-3 rounded border" style="width: 260px;">
                            <img src="~/images/qr.png" class="img-fluid" alt="QR thanh toán" />
                        </div>

                        <div class="flex-grow-1 w-100">
                            <div class="p-3 rounded bg-light border">
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Tổng tiền cần thanh toán</span>
                                    <span class="fw-bold">@total.ToString("#,##0") Vnđ</span>
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <span class="text-muted">Nội dung chuyển khoản</span>
                                <span class="fw-semibold">3TLH-ORDER-@order.Id</span>
                                </div>
                            </div>

                            <form asp-controller="ShoppingCart"
                                  asp-action="ConfirmPayment"
                                  asp-route-id="@order.Id"
                                  method="post"
                                  class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary w-100">
                                    Đã chuyển tiền và tiếp tục
                                </button>
                            </form>

                            <div class="text-muted-small mt-2">
                                Nếu bạn chưa chuyển khoản, bạn có thể quay lại giỏ hàng để chỉnh đơn.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h6 class="mb-3">Tóm tắt đơn hàng</h6>
                    <ul class="list-unstyled mb-3">
                        @foreach (var d in Model.OrderDetails ?? new List<TINH_FINAL_2256.Models.OrderDetail>())
                        {
                            <li class="d-flex justify-content-between align-items-start mb-2">
                                <div class="me-3">
                                    <div class="fw-semibold">@((d.Product?.Name) ?? $"Sản phẩm #{d.ProductId}")</div>
                                    <div class="text-muted-small">Số lượng: @d.Quantity</div>
                                </div>
                                <div class="text-end fw-semibold">@((d.Price * d.Quantity).ToString("#,##0")) Vnđ</div>
                            </li>
                        }
                    </ul>

                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Tổng</span>
                        <span>@total.ToString("#,##0") Vnđ</span>
                    </div>
                    <div class="text-muted-small mt-2">
                        Địa chỉ: @Model.ShippingAddress
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
