@model IEnumerable<TINH_FINAL_2256.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container my-4">
    <!-- Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <div>
                <h2 class="mb-1">
                    <i class="bi bi-receipt me-2"></i>Đơn hàng của tôi
                </h2>
                <p class="text-muted mb-0">Quản lý và theo dõi các đơn hàng của bạn</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-bag-plus me-1"></i>Tiếp tục mua sắm
                </a>
                <a asp-controller="ShoppingCart" asp-action="ExportMyOrdersToExcel" class="btn btn-success">
                    <i class="bi bi-download me-1"></i>Xuất Excel
                </a>
            </div>
        </div>
    </div>

    <!-- Thông báo thành công/lỗi -->
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div style="font-size: 3rem; margin-bottom: 1rem;">
                    <i class="bi bi-inbox text-secondary"></i>
                </div>
                <h5 class="mb-2">Chưa có đơn hàng</h5>
                <p class="text-muted mb-3">Bạn chưa đặt hàng nào. Hãy bắt đầu mua sắm ngay!</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-shop me-1"></i>Khám phá sản phẩm
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Main Orders List -->
            <div class="col-lg-9">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-list-check me-2"></i>Tất cả đơn hàng
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 80px;">Mã đơn</th>
                                        <th style="width: 130px;">Ngày đặt</th>
                                        <th>Sản phẩm</th>
                                        <th style="width: 120px;" class="text-end">Tổng tiền</th>
                                        <th style="width: 110px;">Trạng thái</th>
                                        <th style="width: 100px;" class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        var statusBadgeClass = order.Status switch
                                        {
                                            "Pending" => "bg-warning text-dark",
                                            "Processing" => "bg-info",
                                            "Paid" => "bg-success",
                                            "Shipped" => "bg-primary",
                                            "Delivered" => "bg-success",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };

                                        var statusText = order.Status switch
                                        {
                                            "Pending" => "Chờ thanh toán",
                                            "Processing" => "Đang xử lý",
                                            "Paid" => "Đã thanh toán",
                                            "Shipped" => "Đang giao",
                                            "Delivered" => "Đã giao",
                                            "Cancelled" => "Đã hủy",
                                            _ => order.Status
                                        };

                                        <tr>
                                            <td class="fw-bold">
                                                <i class="bi bi-box me-1" style="color: #0d6efd;"></i>#@order.Id
                                            </td>
                                            <td>
                                                <small>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy")</small>
                                                <br />
                                                <small class="text-muted">@order.OrderDate.ToLocalTime().ToString("HH:mm")</small>
                                            </td>
                                            <td>
                                                @if (order.OrderDetails != null && order.OrderDetails.Any())
                                                {
                                                    <small class="badge bg-light text-dark">@order.OrderDetails.Count() sản phẩm</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td class="text-end fw-bold text-danger">
                                                @order.TotalPrice.ToString("#,##0") đ
                                            </td>
                                            <td>
                                                <span class="badge @statusBadgeClass">@statusText</span>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="OrderDetails" asp-route-id="@order.Id" 
                                                   class="btn btn-sm btn-outline-primary" 
                                                   title="Xem chi tiết">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                @if (order.Status != "Shipped" && order.Status != "Delivered" && order.Status != "Cancelled")
                                                {
                                                    <form asp-action="CancelOrder" method="post" style="display:inline;">
                                                        <input type="hidden" name="id" value="@order.Id" />
                                                        <button type="submit" 
                                                                class="btn btn-sm btn-outline-danger" 
                                                                onclick="return confirm('Bạn có chắc muốn hủy đơn hàng #@order.Id?');" 
                                                                title="Hủy đơn hàng">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Statistics Sidebar -->
            <div class="col-lg-3">
                <!-- Recent Orders Card -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-clock-history me-2"></i>Đơn hàng gần đây
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        @if (Model == null || !Model.Any())
                        {
                            <div class="p-3 text-center text-muted small">
                                <p class="mb-0">Chưa có đơn hàng</p>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var order in Model.Take(5))
                                {
                                    var statusBadgeClass = order.Status switch
                                    {
                                        "Pending" => "bg-warning text-dark",
                                        "Processing" => "bg-info",
                                        "Paid" => "bg-success",
                                        "Shipped" => "bg-primary",
                                        "Delivered" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    };

                                    var statusText = order.Status switch
                                    {
                                        "Pending" => "Chờ TT",
                                        "Processing" => "Xử lý",
                                        "Paid" => "Đã TT",
                                        "Shipped" => "Đang giao",
                                        "Delivered" => "Đã giao",
                                        "Cancelled" => "Hủy",
                                        _ => order.Status
                                    };

                                    <a href="@Url.Action("OrderDetails", new { id = order.Id })" 
                                       class="list-group-item list-group-item-action p-3 text-decoration-none">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div style="flex: 1; min-width: 0;">
                                                <h6 class="mb-1 fw-bold" style="font-size: 0.85rem;">
                                                    Đơn #@order.Id
                                                </h6>
                                                <small class="text-muted d-block">
                                                    @order.OrderDate.ToLocalTime().ToString("dd/MM HH:mm")
                                                </small>
                                            </div>
                                            <div class="text-end flex-shrink-0">
                                                <span class="badge @statusBadgeClass" style="font-size: 0.65rem; white-space: nowrap;">
                                                    @statusText
                                                </span>
                                                <br />
                                                <small class="fw-bold text-danger d-block mt-1">
                                                    @order.TotalPrice.ToString("#,##0") đ
                                                </small>
                                            </div>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Statistics Card -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-bar-chart me-2"></i>Thống kê
                        </h6>
                    </div>
                    <div class="card-body">
                        @{
                            var totalOrders = Model?.Count() ?? 0;
                            var totalSpent = Model?.Sum(o => o.TotalPrice) ?? 0;
                            var pendingOrders = Model?.Count(o => o.Status == "Pending" || o.Status == "Processing") ?? 0;
                            var deliveredOrders = Model?.Count(o => o.Status == "Delivered") ?? 0;
                        }
                        <div class="mb-3 pb-3 border-bottom">
                            <small class="text-muted d-block mb-1">Tổng đơn hàng</small>
                            <h5 class="mb-0 text-primary">@totalOrders</h5>
                        </div>
                        <div class="mb-3 pb-3 border-bottom">
                            <small class="text-muted d-block mb-1">Tổng chi tiêu</small>
                            <h5 class="mb-0 text-danger">@totalSpent.ToString("#,##0") đ</h5>
                        </div>
                        <div class="mb-3 pb-3 border-bottom">
                            <small class="text-muted d-block mb-1">Đang xử lý</small>
                            <h5 class="mb-0 text-warning">@pendingOrders</h5>
                        </div>
                        <div>
                            <small class="text-muted d-block mb-1">Đã giao hàng</small>
                            <h5 class="mb-0 text-success">@deliveredOrders</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Detailed Order View (Optional Accordion) -->
@if (Model != null && Model.Any())
{
    <div class="container mt-5 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">
                    <i class="bi bi-folder-open me-2"></i>Chi tiết đơn hàng
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="accordion" id="orderAccordion">
                    @{
                        int index = 0;
                    }
                    @foreach (var order in Model)
                    {
                        var statusBadgeClass = order.Status switch
                        {
                            "Pending" => "bg-warning text-dark",
                            "Processing" => "bg-info",
                            "Paid" => "bg-success",
                            "Shipped" => "bg-primary",
                            "Delivered" => "bg-success",
                            "Cancelled" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        var statusText = order.Status switch
                        {
                            "Pending" => "Chờ thanh toán",
                            "Processing" => "Đang xử lý",
                            "Paid" => "Đã thanh toán",
                            "Shipped" => "Đang giao",
                            "Delivered" => "Đã giao",
                            "Cancelled" => "Đã hủy",
                            _ => order.Status
                        };

                        <div class="accordion-item border-0 border-bottom">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" 
                                        data-bs-target="#order_@order.Id" aria-expanded="false">
                                    <i class="bi bi-chevron-right me-2"></i>
                                    <span class="fw-bold">Đơn hàng #@order.Id</span>
                                    <span class="ms-auto me-3 text-muted small">
                                        @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                    <span class="badge @statusBadgeClass">@statusText</span>
                                </button>
                            </h2>
                            <div id="order_@order.Id" class="accordion-collapse collapse" data-bs-parent="#orderAccordion">
                                <div class="accordion-body p-4 bg-light">
                                    <!-- Order Items -->
                                    <h6 class="fw-bold mb-3">Sản phẩm đã đặt</h6>
                                    <div class="table-responsive mb-3">
                                        <table class="table table-sm mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Sản phẩm</th>
                                                    <th class="text-center">Số lượng</th>
                                                    <th class="text-end">Đơn giá</th>
                                                    <th class="text-end">Thành tiền</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (order.OrderDetails != null && order.OrderDetails.Any())
                                                {
                                                    @foreach (var detail in order.OrderDetails)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <strong>@(detail.Product?.Name ?? $"Sản phẩm #{detail.ProductId}")</strong>
                                                            </td>
                                                            <td class="text-center">@detail.Quantity</td>
                                                            <td class="text-end">@detail.Price.ToString("#,##0") đ</td>
                                                            <td class="text-end fw-bold">@((detail.Price * detail.Quantity).ToString("#,##0")) đ</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Order Info -->
                                    <hr />
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <h6 class="fw-bold mb-2">Thông tin giao hàng</h6>
                                            <div class="small">
                                                <p class="mb-1"><strong>Địa chỉ:</strong> @order.ShippingAddress</p>
                                                <p class="mb-1"><strong>Số điện thoại:</strong> @order.PhoneNumber</p>
                                                @if (!string.IsNullOrEmpty(order.Notes))
                                                {
                                                    <p class="mb-0"><strong>Ghi chú:</strong> @order.Notes</p>
                                                }
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <h6 class="fw-bold mb-2">Tổng kết</h6>
                                            <div class="bg-white p-3 rounded border">
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span>Tổng tiền:</span>
                                                    <strong>@order.TotalPrice.ToString("#,##0") đ</strong>
                                                </div>
                                                <div class="d-flex justify-content-between">
                                                    <span>Trạng thái:</span>
                                                    <span class="badge @statusBadgeClass">@statusText</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="mt-3">
                                        <a asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye me-1"></i>Xem chi tiết đầy đủ
                                        </a>
                                        @if (order.Status != "Shipped" && order.Status != "Delivered" && order.Status != "Cancelled")
                                        {
                                            <form asp-action="CancelOrder" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger" 
                                                        onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?');">
                                                    <i class="bi bi-trash me-1"></i>Hủy đơn
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
