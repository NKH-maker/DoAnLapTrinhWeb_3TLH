@model TINH_FINAL_2256.Models.Order
@using TINH_FINAL_2256.Extensions
@using System.Linq

@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    var cart = Context.Session.GetObjectFromJson<TINH_FINAL_2256.Models.ShoppingCart>("Cart") ?? new TINH_FINAL_2256.Models.ShoppingCart();
    var subtotal = cart.Items?.Any() == true ? cart.Items.Sum(i => i.Price * i.Quantity) : 0m;
    var shippingFee = 0m;
    var total = subtotal + shippingFee;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="ShoppingCart" asp-action="Index"><i class="bi bi-cart me-1"></i>Giỏ hàng</a></li>
        <li class="breadcrumb-item active"><i class="bi bi-credit-card me-1"></i>Thanh toán</li>
    </ol>
</nav>

<h1 class="page-title mb-4">
    <i class="bi bi-credit-card me-2"></i>Hoàn tất thanh toán
</h1>

@if (cart == null || cart.Items == null || !cart.Items.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag-x" style="font-size: 4rem; color: var(--text-secondary);"></i>
        <h4 class="mt-3 text-secondary">Giỏ hàng trống</h4>
        <p class="text-secondary mb-4">Không có sản phẩm nào để thanh toán.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-arrow-left me-2"></i>Quay lại mua sắm
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Delivery & Payment Form -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-4">
                        <i class="bi bi-truck me-2"></i>Thông tin giao hàng
                    </h5>

                    @* Show validation summary *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

                    <form asp-controller="ShoppingCart" asp-action="Checkout" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Shipping Address -->
                        <div class="mb-4">
                            <label asp-for="ShippingAddress" class="form-label">
                                <i class="bi bi-geo-alt me-2"></i>Địa chỉ giao hàng
                            </label>
                            <textarea asp-for="ShippingAddress" class="form-control form-control-lg" 
                                      rows="2" 
                                      placeholder="Nhập địa chỉ giao hàng đầy đủ..." 
                                      required></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- Phone Number -->
                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label">
                                <i class="bi bi-telephone me-2"></i>Số điện thoại
                            </label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg" type="tel" placeholder="Số điện thoại liên hệ" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- Notes -->
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label">
                                <i class="bi bi-chat me-2"></i>Ghi chú (tuỳ chọn)
                            </label>
                            <textarea asp-for="Notes" class="form-control form-control-lg" 
                                      rows="3" 
                                      placeholder="Ví dụ: Giao vào giờ nào, ghi chú cho shipper..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small d-block mt-1"></span>
                            <small class="text-secondary d-block mt-1">Các yêu cầu đặc biệt sẽ giúp chúng tôi phục vụ bạn tốt hơn</small>
                        </div>

                        <!-- Order Items Summary -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3">
                                <i class="bi bi-bag-check me-2"></i>Các mặt hàng trong đơn
                            </h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-borderless">
                                    <tbody>
                                        @foreach (var item in cart.Items)
                                        {
                                            <tr>
                                                <td class="text-secondary">
                                                    <small>@item.Name</small>
                                                </td>
                                                <td class="text-end text-secondary">
                                                    <small>x@item.Quantity</small>
                                                </td>
                                                <td class="text-end fw-bold text-danger">
                                                    <small>@((item.Price * item.Quantity).ToString("#,##0")) đ</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-2"></i>Xác nhận và đặt hàng
                            </button>
                        </div>

                        <!-- Additional Info -->
                        <div class="alert alert-info mt-3 mb-0" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            <small>
                                Sau khi đặt hàng, bạn sẽ nhận được xác nhận qua email và SMS. Chúng tôi sẽ giao hàng trong 1-2 ngày làm việc.
                            </small>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 100px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">
                        <i class="bi bi-receipt me-2"></i>Tóm tắt đơn hàng
                    </h5>

                    <!-- Order Items -->
                    <div class="mb-3 pb-3 border-bottom">
                        @foreach (var item in cart.Items)
                        {
                            <div class="d-flex justify-content-between mb-2 small">
                                <div>
                                    <p class="mb-0 fw-bold">@item.Name</p>
                                    <p class="text-secondary mb-0">Số lượng: <strong>@item.Quantity</strong></p>
                                </div>
                                <div class="text-end fw-bold">
                                    @((item.Price * item.Quantity).ToString("#,##0")) đ
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pricing Summary -->
                    <div class="mb-2">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Tạm tính:</span>
                            <span class="fw-bold">@subtotal.ToString("#,##0") đ</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Phí vận chuyển:</span>
                            <span class="fw-bold text-success">
                                <i class="bi bi-check-circle me-1"></i>Miễn phí
                            </span>
                        </div>
                    </div>

                    <hr class="my-3" />

                    <!-- Total -->
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold">Tổng cộng:</span>
                        <span class="fs-4 fw-bold text-danger">@total.ToString("#,##0") đ</span>
                    </div>

                    <!-- Trust Badges -->
                    <div class="mt-4 pt-4 border-top">
                        <div class="mb-2 text-center">
                            <small class="text-success d-block mb-2">
                                <i class="bi bi-shield-check me-1"></i>Thanh toán an toàn
                            </small>
                            <small class="text-secondary d-block">
                                <i class="bi bi-truck me-1"></i>Giao hàng nhanh chóng
                            </small>
                        </div>
                    </div>

                    <!-- Back Button -->
                    <a asp-controller="ShoppingCart" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 mt-3">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại giỏ hàng
                    </a>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const form = document.querySelector('form');
                if (form) {
                    form.addEventListener('submit', function (e) {
                        if (!form.checkValidity()) {
                            e.preventDefault();
                            e.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    });
                }
            });
        </script>
    }
}