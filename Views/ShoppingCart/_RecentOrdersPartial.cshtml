@model List<TINH_FINAL_2256.Models.Order>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-secondary py-3">
        <p class="small mb-0">Chưa có đơn hàng nào</p>
    </div>
}
else
{
    <div class="list-group list-group-sm">
        @foreach (var order in Model)
        {
            var statusBadgeClass = order.Status switch
            {
                "Pending" => "bg-warning text-dark",
                "Processing" => "bg-info",
                "Paid" => "bg-success",
                "Shipped" => "bg-primary",
                "Delivered" => "bg-success",
                "Cancelled" => "bg-danger",
                _ => "bg-secondary"
            };

            var statusText = order.Status switch
            {
                "Pending" => "Chờ thanh toán",
                "Processing" => "Đang xử lý",
                "Paid" => "Đã thanh toán",
                "Shipped" => "Đang giao",
                "Delivered" => "Đã giao",
                "Cancelled" => "Đã hủy",
                _ => order.Status
            };

            <a href="@Url.Action("OrderDetails", "ShoppingCart", new { id = order.Id })" 
               class="list-group-item list-group-item-action py-2 px-3" 
               data-bs-dismiss="modal">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div style="flex: 1; min-width: 0;">
                        <div class="fw-bold text-dark mb-1" style="font-size: 0.9rem;">
                            Đơn #@order.Id
                        </div>
                        <div class="small text-secondary mb-1">
                            @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="small text-secondary">
                            @(order.OrderDetails?.Count ?? 0) sản phẩm
                        </div>
                    </div>
                    <div class="text-end flex-shrink-0">
                        <div class="fw-bold text-danger mb-1" style="font-size: 0.85rem; white-space: nowrap;">
                            @order.TotalPrice.ToString("#,##0") đ
                        </div>
                        <span class="badge @statusBadgeClass" style="font-size: 0.65rem; white-space: nowrap;">
                            @statusText
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>
}
