@model IEnumerable<TINH_FINAL_2256.Models.Order>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-secondary py-3">
        <p class="small mb-0">Chưa có đơn hàng nào</p>
    </div>
}
else
{
    <div class="list-group list-group-sm">
        @foreach (var order in Model)
        {
            var statusBadgeClass = order.Status switch
            {
                "Pending" => "bg-warning text-dark",
                "Processing" => "bg-info",
                "Paid" => "bg-success",
                "Shipped" => "bg-primary",
                "Delivered" => "bg-success",
                "Cancelled" => "bg-danger",
                _ => "bg-secondary"
            };

            var statusText = order.Status switch
            {
                "Pending" => "Chờ thanh toán",
                "Processing" => "Đang xử lý",
                "Paid" => "Đã thanh toán",
                "Shipped" => "Đang giao",
                "Delivered" => "Đã giao",
                "Cancelled" => "Đã hủy",
                _ => order.Status
            };

            <button type="button" class="list-group-item list-group-item-action py-2 px-3 text-start"
                    onclick="viewOrderDetails(@order.Id)">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div style="flex: 1; min-width: 0;">
                        <div class="fw-bold text-dark mb-1" style="font-size: 0.9rem;">
                            Đơn #@order.Id - <small class="text-secondary fw-normal">@order.ApplicationUser?.Email</small>
                        </div>
                        <div class="small text-secondary mb-1">
                            @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="small text-secondary">
                            @(order.OrderDetails?.Count ?? 0) sản phẩm
                        </div>
                    </div>
                    <div class="text-end flex-shrink-0">
                        <div class="fw-bold text-danger mb-1" style="font-size: 0.85rem; white-space: nowrap;">
                            @order.TotalPrice.ToString("#,##0") đ
                        </div>
                        <span class="badge @statusBadgeClass" style="font-size: 0.65rem; white-space: nowrap;">
                            @statusText
                        </span>
                    </div>
                </div>
            </button>
        }
    </div>

    <div class="mt-3 d-flex justify-content-between align-items-center">
        <a asp-action="AdminOrders" class="btn btn-sm btn-link">Xem tất cả đơn hàng</a>
        <div class="d-flex gap-2">
            <a asp-controller="ShoppingCart" asp-action="ExportOrdersToExcel" class="btn btn-sm btn-success">
                <i class="bi bi-download me-1"></i>Xuất Excel
            </a>
            <a href="/hangfire" target="_blank" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-clock-history me-1"></i>Hangfire
            </a>
        </div>
    </div>
}