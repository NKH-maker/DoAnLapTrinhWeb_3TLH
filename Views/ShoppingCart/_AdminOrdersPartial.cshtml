@model IEnumerable<TINH_FINAL_2256.Models.Order>

<h6 class="fw-bold mb-3">Đơn hàng mới từ khách hàng</h6>
<div class="list-group">
    @foreach (var order in Model)
    {
        <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <span class="fw-bold">#@order.Id</span> - <small>@order.ApplicationUser?.Email</small>
                    <div class="small text-secondary">Ngày: @order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                    <div class="small text-primary fw-bold">Tổng: @order.TotalPrice.ToString("#,##0") Vnđ</div>
                </div>
                <div class="text-end">
                    <span class="badge bg-info mb-1">@order.Status</span><br />
                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                </div>
            </div>
        </div>
    }
</div>
<div class="mt-3 text-center">
    <a asp-action="AdminOrders" class="btn btn-sm btn-link">Xem tất cả đơn hàng</a>
</div>