@model TINH_FINAL_2256.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var qrCodeBase64 = ViewData["OrderQRCode"] as string;

    var statusBadgeClass = Model.Status switch
    {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-info",
        "Paid" => "bg-success",
        "Shipped" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };

    var statusText = Model.Status switch
    {
        "Pending" => "Chờ thanh toán",
        "Processing" => "Đang xử lý",
        "Paid" => "Đã thanh toán",
        "Shipped" => "Đang giao",
        "Delivered" => "Đã giao",
        "Cancelled" => "Đã hủy",
        _ => Model.Status
    };
}

<div class="container my-4">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <div>
            <h2 class="mb-1">Chi tiết đơn hàng #@Model.Id</h2>
            <p class="text-muted mb-0">Ngày đặt: @Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <span class="badge @statusBadgeClass fs-5">@statusText</span>
    </div>

    <!-- Main Content -->
    <div class="row g-4 mb-4">
        <!-- Left Column - Order Items & Details -->
        <div class="col-lg-8">
            <!-- Products Table -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-box me-2"></i>Chi tiết sản phẩm
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center" style="width: 100px;">Số lượng</th>
                                    <th class="text-end" style="width: 120px;">Đơn giá</th>
                                    <th class="text-end" style="width: 120px;">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                                {
                                    @foreach (var d in Model.OrderDetails)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    @if (!string.IsNullOrEmpty(d.Product?.ImageUrl))
                                                    {
                                                        <div style="width:50px; height:50px; overflow:hidden; border-radius:6px; flex-shrink:0;">
                                                            <img src="@d.Product.ImageUrl" alt="@d.Product?.Name" 
                                                                 style="width:100%; height:100%; object-fit:cover;" />
                                                        </div>
                                                    }
                                                    <div>
                                                        <strong>@d.Product?.Name</strong>
                                                        @if (d.Product != null)
                                                        {
                                                            <br />
                                                            <small class="text-muted">ID: @d.Product.Id</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-light text-dark">@d.Quantity</span>
                                            </td>
                                            <td class="text-end">
                                                @d.Price.ToString("#,##0") đ
                                            </td>
                                            <td class="text-end fw-bold text-danger">
                                                @((d.Quantity * d.Price).ToString("#,##0")) đ
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            Không có sản phẩm nào trong đơn hàng này
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Shipping Information -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-truck me-2"></i>Thông tin giao hàng
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="text-muted small fw-bold d-block mb-1">
                                    <i class="bi bi-geo-alt me-1"></i>Địa chỉ giao hàng
                                </label>
                                <p class="mb-0 fw-semibold">@Model.ShippingAddress</p>
                            </div>
                            <div>
                                <label class="text-muted small fw-bold d-block mb-1">
                                    <i class="bi bi-telephone me-1"></i>Số điện thoại
                                </label>
                                <p class="mb-0 fw-semibold">@Model.PhoneNumber</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            @if (!string.IsNullOrWhiteSpace(Model.Notes))
                            {
                                <div>
                                    <label class="text-muted small fw-bold d-block mb-1">
                                        <i class="bi bi-chat-left-text me-1"></i>Ghi chú
                                    </label>
                                    <p class="mb-0 fw-semibold">@Model.Notes</p>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small">
                                    <i class="bi bi-info-circle me-1"></i>Không có ghi chú
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Order Summary & Customer Info -->
        <div class="col-lg-4">
            <!-- Order Summary -->
            <div class="card border-0 shadow-sm mb-4 sticky-top" style="top: 20px;">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-calculator me-2"></i>Tổng kết đơn hàng
                    </h5>
                </div>
                <div class="card-body">
                    @{
                        var subtotal = Model.OrderDetails?.Sum(d => d.Price * d.Quantity) ?? 0;
                        var tax = 0m; // Nếu có tax, tính toán tại đây
                        var shipping = 0m; // Nếu có phí ship, tính toán tại đây
                    }
                    
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tổng tiền hàng:</span>
                            <span>@subtotal.ToString("#,##0") đ</span>
                        </div>
                        @if (tax > 0)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>Thuế:</span>
                                <span>@tax.ToString("#,##0") đ</span>
                            </div>
                        }
                        @if (shipping > 0)
                        {
                            <div class="d-flex justify-content-between">
                                <span>Phí giao hàng:</span>
                                <span>@shipping.ToString("#,##0") đ</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                        <span>Tổng cộng:</span>
                        <span class="text-danger">@Model.TotalPrice.ToString("#,##0") đ</span>
                    </div>

                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        <small>
                            <strong>Trạng thái:</strong> @statusText
                        </small>
                    </div>
                </div>
            </div>

            <!-- Customer Information -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i>Thông tin khách hàng
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small fw-bold d-block mb-1">
                            <i class="bi bi-person me-1"></i>Tên khách hàng
                        </label>
                        <p class="mb-0 fw-semibold">@(Model.ApplicationUser?.FullName ?? Model.ApplicationUser?.UserName ?? "N/A")</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-bold d-block mb-1">
                            <i class="bi bi-envelope me-1"></i>Email
                        </label>
                        <p class="mb-0 fw-semibold">
                            <a href="mailto:@Model.ApplicationUser?.Email" class="text-decoration-none">
                                @Model.ApplicationUser?.Email
                            </a>
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-bold d-block mb-1">
                            <i class="bi bi-calendar me-1"></i>Ngày đặt hàng
                        </label>
                        <p class="mb-0 fw-semibold">@Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    
                    <!-- QR Code -->
                    @if (!string.IsNullOrEmpty(qrCodeBase64))
                    {
                        <div class="border-top pt-3 mt-3">
                            <label class="text-muted small fw-bold d-block mb-2 text-center">
                                <i class="bi bi-qr-code me-1"></i>Mã QR theo dõi
                            </label>
                            <div class="text-center">
                                <img src="data:image/png;base64,@qrCodeBase64" alt="Order QR Code" 
                                     class="img-fluid border rounded" style="max-width: 150px;" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex gap-2 justify-content-between flex-wrap">
                <a asp-action="MyOrders" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách đơn hàng
                </a>
                
                <div class="d-flex gap-2">
                    @if (User.IsInRole("Customer") && (Model.Status == "Pending" || Model.Status == "Processing" || Model.Status == "Paid"))
                    {
                        <form asp-action="CancelOrder" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger" 
                                    onclick="return confirm('Bạn chắc chắn muốn hủy đơn hàng #@Model.Id?')">
                                <i class="bi bi-x-circle me-1"></i>Hủy đơn hàng
                            </button>
                        </form>
                    }

                    <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i>In đơn hàng
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 📧 Notification Toast -->
<div id="notificationToast" class="toast position-fixed bottom-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header bg-info text-white">
        <strong class="me-auto">Thông báo</strong>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body" id="notificationMessage">
    </div>
</div>

<!-- 🔔 Real-time Notifications using SignalR -->
<script src="~/lib/signalr/signalr.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Kết nối tới NotificationHub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/notifications")
            .withAutomaticReconnect()
            .build();

        // Nhận order status update
        connection.on("ReceiveOrderNotification", (orderId, message) => {
            console.log(`Order ${orderId}: ${message}`);
            showNotification(message);
        });

        // Nhận order cancelled notification
        connection.on("OrderCancelled", (orderId) => {
            console.log(`Order ${orderId} was cancelled`);
            showNotification(`Đơn hàng #${orderId} đã bị hủy`);
            setTimeout(() => {
                window.location.href = '@Url.Action("MyOrders", "ShoppingCart")';
            }, 2000);
        });

        connection.start().catch(err => console.error(err));

        // Hiển thị notification toast
        function showNotification(message) {
            const messageEl = document.getElementById('notificationMessage');
            messageEl.textContent = message;
            const toast = new bootstrap.Toast(document.getElementById('notificationToast'));
            toast.show();
        }
    });
</script>

<!-- Print Styles -->
<style media="print">
    .btn, .card-header, .sticky-top, .d-flex.gap-2 {
        display: none !important;
    }
    .table, .card-body {
        border: 1px solid #000 !important;
    }
</style>