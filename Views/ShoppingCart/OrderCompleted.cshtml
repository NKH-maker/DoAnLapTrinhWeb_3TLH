@model TINH_FINAL_2256.Models.Order
@using System.Linq

@{
    ViewData["Title"] = "Đặt hàng thành công";
    var order = Model;
    var total = order.TotalPrice;
    var qrCodeBase64 = ViewData["OrderQRCode"] as string;
}

<div class="container my-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <h2 class="mb-1">Đặt hàng thành công</h2>
                    <div class="text-muted">
                        Cảm ơn bạn đã mua hàng tại 3TLH Phone.
                    </div>
                </div>
                <span class="badge bg-success fs-6">Đơn hàng #@order.Id</span>
            </div>

            <hr class="my-4" />

            <div class="row g-3">
                <div class="col-lg-7">
                    <h5 class="mb-3">Sản phẩm đã đặt</h5>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.OrderDetails ?? new List<TINH_FINAL_2256.Models.OrderDetail>())
                                {
                                    <tr>
                                        <td class="fw-semibold">@((d.Product?.Name) ?? $"Sản phẩm #{d.ProductId}")</td>
                                        <td class="text-center">@d.Quantity</td>
                                        <td class="text-end">@d.Price.ToString("#,##0") Vnđ</td>
                                        <td class="text-end fw-semibold">@((d.Price * d.Quantity).ToString("#,##0")) Vnđ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-5">
                    <h5 class="mb-3">Thông tin đơn hàng</h5>
                    <div class="p-3 rounded border bg-light">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Ngày đặt</span>
                            <span class="fw-semibold">@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <span class="text-muted">Địa chỉ</span>
                            <span class="fw-semibold text-end" style="max-width: 65%;">@order.ShippingAddress</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(order.Notes))
                        {
                            <div class="mt-2">
                                <div class="text-muted">Ghi chú</div>
                                <div class="fw-semibold">@order.Notes</div>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Tổng thanh toán</span>
                            <span>@total.ToString("#,##0") Vnđ</span>
                        </div>

                        <!-- 🔗 QR Code Tracking -->
                        @if (!string.IsNullOrEmpty(qrCodeBase64))
                        {
                            <hr />
                            <div class="text-center">
                                <div class="text-muted small mb-2">Quét mã QR để theo dõi đơn hàng</div>
                                <img src="data:image/png;base64,@qrCodeBase64" alt="Order QR Code" class="img-fluid" style="max-width: 150px;" />
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-success">
                            Tiếp tục mua sắm
                        </a>
                        <a asp-controller="ShoppingCart" asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-outline-secondary">
                            Xem chi tiết đơn hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 🔔 Real-time Notifications using SignalR -->
<script src="~/lib/signalr/signalr.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Kết nối tới NotificationHub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/notifications")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveOrderNotification", (orderId, message) => {
            console.log(`Order ${orderId}: ${message}`);
            // Cập nhật UI nếu cần
        });

        connection.start().catch(err => console.error(err));
    });
</script>