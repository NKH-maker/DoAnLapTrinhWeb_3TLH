@model IEnumerable<TINH_FINAL_2256.Models.Order>

@{
    ViewData["Title"] = "đơn hàng - Admin";
}

<h2>Danh sách đơn hàng</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Người mua </th>
            <th>Ngày</th>
            <th>Tổng tiền</th>
            <th>Số mặt hàng</th>
            <th>Chi tiết</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.ApplicationUser?.Email</td>
                <td>@o.OrderDate.ToString("g")</td>
                <td>@o.TotalPrice.ToString("#,##0") VnD </td>
                <td>@(o.OrderDetails?.Sum(d => d.Quantity) ?? 0)</td>
                <td>
                    <a asp-controller="ShoppingCart" asp-action="OrderDetails" asp-route-id="@o.Id" class="btn btn-sm btn-primary">Xem</a>
                </td>
            </tr>
        }
    </tbody>
</table>