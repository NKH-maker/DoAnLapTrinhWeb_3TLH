@model IEnumerable<TINH_FINAL_2256.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng - Admin";
}

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="mb-0">Danh sách đơn hàng</h2>
                    <p class="text-muted small mb-0">Quản lý tất cả đơn hàng trong hệ thống</p>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mb-0 me-2">@TempData["ErrorMessage"]</div>
                    }
                    <a href="@Url.Action("ExportOrdersToExcel", "ShoppingCart")" class="btn btn-success btn-sm" title="Xuất Excel" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-download me-1"></i>Xuất Excel
                    </a>
                    <a href="/hangfire" target="_blank" class="btn btn-outline-secondary btn-sm" title="Hangfire Dashboard">
                        <i class="bi bi-clock-history me-1"></i>Hangfire
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px;">Mã</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-center">Số mặt hàng</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@o.Id</td>
                                <td>@o.ApplicationUser?.Email</td>
                                <td>@o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end text-danger fw-bold">@o.TotalPrice.ToString("#,##0") đ</td>
                                <td class="text-center">@(o.OrderDetails?.Sum(d => d.Quantity) ?? 0)</td>
                                <td class="text-center">
                                    <a asp-controller="ShoppingCart" asp-action="OrderDetails" asp-route-id="@o.Id" class="btn btn-sm btn-primary">Xem</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>