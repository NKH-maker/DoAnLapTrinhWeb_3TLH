@model ShoppingCart
@using System.Linq

<div class="container my-4">
    <h2 class="mb-3">Giỏ hàng của bạn</h2>

    @if (Model == null || Model.Items == null || !Model.Items.Any())
    {
        <div class="alert alert-info">Giỏ hàng trống.</div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card table-cart p-3 mb-3">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-end">Tổng</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div style="width:64px; height:64px; overflow:hidden; border-radius:6px; background:#f5f5f7;">
                                                    <img src="@item.ImageUrl" style="width:100%; height:100%; object-fit:cover;" />
                                                </div>
                                                <div>
                                                    <p class="mb-0 fw-bold">@item.Name</p>
                                                    <p class="small text-secondary mb-0">@item.CategoryName</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm" role="group" aria-label="quantity">
                                                <a asp-controller="ShoppingCart"
                                                   asp-action="DecreaseQuantity"
                                                   asp-route-productId="@item.ProductId"
                                                   class="btn btn-outline-secondary">-</a>
                                                <span class="btn btn-light disabled" style="min-width:52px">@item.Quantity</span>
                                                <a asp-controller="ShoppingCart"
                                                   asp-action="IncreaseQuantity"
                                                   asp-route-productId="@item.ProductId"
                                                   class="btn btn-outline-secondary">+</a>
                                            </div>
                                        </td>
                                        <td class="text-end">@item.Price.ToString("#,##0") đ</td>
                                        <td class="text-end">@((item.Price * item.Quantity).ToString("#,##0")) đ</td>
                                        <td class="text-end">
                                            <a asp-controller="ShoppingCart"
                                               asp-action="RemoveFromCart"
                                               asp-route-productId="@item.ProductId"
                                               class="btn btn-danger btn-sm">Xóa</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
                    <a asp-action="Checkout" class="btn btn-primary">Thanh toán</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3 shadow-sm">
                    <h5>Tóm tắt đơn hàng</h5>
                    <hr />
                    @{
                        var subtotal = Model.Items.Sum(i => i.Price * i.Quantity);
                    }
                    <div class="d-flex justify-content-between">
                        <span class="text-secondary">Tạm tính</span>
                        <span class="fw-bold">@subtotal.ToString("#,##0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span class="text-secondary">Phí vận chuyển</span>
                        <span class="fw-bold text-success">Miễn phí</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Tổng</span>
                        <span>@subtotal.ToString("#,##0") đ</span>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <a asp-action="Checkout" class="btn btn-success">Thanh toán</a>
                        <a asp-controller="ShoppingCart" asp-action="MyOrders" class="btn btn-outline-secondary">Đơn hàng của tôi</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>