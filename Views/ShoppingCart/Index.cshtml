@model ShoppingCart
@using System.Linq

<div class="container my-4">
    <h2 class="mb-3">Giỏ hàng của bạn</h2>

    @if (Model == null || Model.Items == null || !Model.Items.Any())
    {
        <div class="alert alert-info">Giỏ hàng trống.</div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="table-cart p-3 mb-3">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Giá</th>
                                <th class="text-end">Tổng</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.Price.ToString("#,##0") Vnđ</td>
                                    <td class="text-end">@((item.Price * item.Quantity).ToString("#,##0")) Vnđ</td>
                                    <td class="text-end">
                                        <a asp-controller="ShoppingCart"
                                           asp-action="RemoveFromCart"
                                           asp-route-productId="@item.ProductId"
                                           class="btn btn-danger btn-sm">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Tóm tắt đơn hàng</h5>
                    <hr />
                    @{
                        var subtotal = Model.Items.Sum(i => i.Price * i.Quantity);
                    }
                    <p class="d-flex justify-content-between"><span>Tạm tính:</span><span>@subtotal.ToString("#,##0") Vnđ</span></p>
                    <p class="d-flex justify-content-between"><span>Phí vận chuyển:</span><span>0 Vnđ</span></p>
                    <hr />
                    <p class="d-flex justify-content-between fw-bold"><span>Tổng:</span><span>@subtotal.ToString("#,##0") Vnđ</span></p>

                    <div class="d-grid gap-2">
                        <a asp-action="Checkout" class="btn btn-success">Tới trang thanh toán</a>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>